#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path

SKIP_DIRS = {"node_modules", ".cache", ".next", "dist", "build"}


@dataclass(frozen=True)
class Worktree:
    path: Path
    branch: str


@dataclass(frozen=True)
class Candidate:
    primary: Path
    worktree: Worktree
    dirty: bool | None


@dataclass
class Totals:
    clean: int = 0
    dirty: int = 0
    removed: int = 0
    skipped: int = 0


def registry_path() -> Path:
    explicit = os.environ.get("WORKTREE_LAUNCHER_REGISTRY")
    if explicit:
        return canonical(explicit)

    xdg_state = os.environ.get("XDG_STATE_HOME")
    if xdg_state:
        return canonical(Path(xdg_state) / "worktree-launcher" / "worktrees.tsv")

    return canonical(Path.home() / ".local/state/worktree-launcher/worktrees.tsv")


def run_git(cwd: Path, args: list[str], *, check: bool = False) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", "-C", str(cwd), *args],
        check=check,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def require_git(cwd: Path, args: list[str]) -> str:
    result = run_git(cwd, args)
    if result.returncode != 0:
        raise RuntimeError(result.stderr.strip() or f"git {' '.join(args)} failed")
    return result.stdout


def canonical(path: str | Path) -> Path:
    return Path(path).expanduser().resolve()


def path_is_under(path: Path, root: Path) -> bool:
    try:
        path.relative_to(root)
        return True
    except ValueError:
        return False


def append_registry_entry(primary: Path, worktree: Worktree) -> None:
    registry = registry_path()
    registry.parent.mkdir(parents=True, exist_ok=True)
    with registry.open("a", encoding="utf-8") as file:
        file.write(f"{primary}\t{worktree.path}\t{worktree.branch}\t0\n")


def registry_candidates(scan_roots: list[Path]) -> list[Candidate]:
    registry = registry_path()
    if not registry.exists():
        return []

    candidates: list[Candidate] = []
    seen: set[tuple[Path, Path]] = set()

    with registry.open("r", encoding="utf-8") as file:
        for line in file:
            fields = line.rstrip("\n").split("\t")
            if len(fields) < 3:
                continue

            primary = canonical(fields[0])
            worktree_path = canonical(fields[1])
            branch = fields[2] or "detached"

            if not any(path_is_under(primary, root) or path_is_under(worktree_path, root) for root in scan_roots):
                continue

            key = (primary, worktree_path)
            if key in seen:
                continue
            seen.add(key)

            if worktree_path.exists():
                candidates.append(Candidate(primary, Worktree(worktree_path, branch), dirty=None))

    return candidates


def parse_worktree_list(output: str) -> list[Worktree]:
    worktrees: list[Worktree] = []
    current_path: Path | None = None
    current_branch = "detached"

    def flush() -> None:
        nonlocal current_path, current_branch
        if current_path is not None:
            worktrees.append(Worktree(current_path, current_branch))
        current_path = None
        current_branch = "detached"

    for line in output.splitlines():
        if not line:
            flush()
            continue

        if line.startswith("worktree "):
            flush()
            current_path = canonical(line.removeprefix("worktree "))
        elif line.startswith("branch refs/heads/"):
            current_branch = line.removeprefix("branch refs/heads/")
        elif line.startswith("branch "):
            current_branch = line.removeprefix("branch ")

    flush()
    return worktrees


def primary_for_repo_path(repo_path: Path) -> Path | None:
    result = run_git(repo_path, ["worktree", "list", "--porcelain"])
    if result.returncode != 0:
        return None

    worktrees = parse_worktree_list(result.stdout)
    if not worktrees:
        return None

    return worktrees[0].path


def is_inside_git_repo() -> bool:
    return run_git(Path.cwd(), ["rev-parse", "--is-inside-work-tree"]).returncode == 0


def current_primary_worktree() -> Path:
    repo_root = canonical(require_git(Path.cwd(), ["rev-parse", "--show-toplevel"]).strip())
    primary = primary_for_repo_path(repo_root)
    if primary is None:
        raise RuntimeError(f"could not resolve primary worktree for {repo_root}")
    return primary


def has_launcher_sibling(primary: Path) -> bool:
    prefix = f"{primary.name}-"
    try:
        for entry in primary.parent.iterdir():
            if entry.is_dir() and entry.name.startswith(prefix):
                return True
    except OSError:
        return False
    return False


def primary_from_git_file(repo_path: Path) -> Path | None:
    git_file = repo_path / ".git"
    try:
        content = git_file.read_text(encoding="utf-8").strip()
    except OSError:
        return None

    if not content.startswith("gitdir:"):
        return None

    git_dir_text = content.removeprefix("gitdir:").strip()
    git_dir = Path(git_dir_text)
    if not git_dir.is_absolute():
        git_dir = repo_path / git_dir
    git_dir = git_dir.resolve()

    marker = f"{os.sep}.git{os.sep}worktrees{os.sep}"
    git_dir_string = str(git_dir)
    if marker not in git_dir_string:
        return primary_for_repo_path(repo_path)

    primary_text = git_dir_string.split(marker, 1)[0]
    return canonical(primary_text)


def worktree_path_from_gitdir_marker(marker_file: Path) -> Path | None:
    try:
        gitdir_path = Path(marker_file.read_text(encoding="utf-8").strip())
    except OSError:
        return None

    if not gitdir_path.is_absolute():
        gitdir_path = marker_file.parent / gitdir_path

    git_file = gitdir_path.resolve().parent / ".git"
    if git_file.exists():
        return canonical(git_file.parent)

    return None


def branch_from_marker(marker_dir: Path) -> str:
    try:
        head = (marker_dir / "HEAD").read_text(encoding="utf-8").strip()
    except OSError:
        return "detached"

    prefix = "ref: refs/heads/"
    if head.startswith(prefix):
        return head.removeprefix(prefix)

    return "detached"


def read_marker_candidates(primary: Path) -> list[Worktree]:
    worktrees_dir = primary / ".git" / "worktrees"
    if not worktrees_dir.is_dir():
        return []

    repo_name = primary.name
    parent = primary.parent
    prefix = str(parent / f"{repo_name}-")
    worktrees: list[Worktree] = []

    for marker_file in sorted(worktrees_dir.glob("*/gitdir")):
        worktree_path = worktree_path_from_gitdir_marker(marker_file)
        if worktree_path is None:
            continue
        if str(worktree_path).startswith(prefix):
            worktrees.append(
                Worktree(
                    worktree_path,
                    branch_from_marker(marker_file.parent),
                )
            )

    return worktrees


def discover_primary_worktrees(scan_root: Path, max_depth: int | None) -> list[Path]:
    primary_worktrees: list[Path] = []
    seen: set[Path] = set()

    def add_primary(primary: Path | None) -> None:
        if primary is None or primary in seen or not primary.exists():
            return
        seen.add(primary)
        primary_worktrees.append(primary)

    for current, dirs, files in os.walk(scan_root):
        current_path = Path(current)

        try:
            depth = len(current_path.relative_to(scan_root).parts)
        except ValueError:
            depth = 0

        if ".git" in dirs:
            primary = canonical(current_path)
            if (primary / ".git" / "worktrees").is_dir() and has_launcher_sibling(primary):
                add_primary(primary)
            dirs.remove(".git")

        if ".git" in files:
            add_primary(primary_from_git_file(canonical(current_path)))

        dirs[:] = [name for name in dirs if name not in SKIP_DIRS]

        if max_depth is not None and depth >= max_depth:
            dirs[:] = []

    return primary_worktrees


def refresh_registry(scan_roots: list[Path], max_depth: int | None) -> list[Candidate]:
    candidates: list[Candidate] = []
    seen: set[tuple[Path, Path]] = set()

    for scan_root in scan_roots:
        for primary in discover_primary_worktrees(scan_root, max_depth):
            for worktree in candidate_worktrees(primary):
                key = (primary, worktree.path)
                if key in seen:
                    continue
                seen.add(key)
                append_registry_entry(primary, worktree)
                candidates.append(Candidate(primary, worktree, dirty=None))

    return candidates


def candidate_worktrees(primary: Path) -> list[Worktree]:
    marker_worktrees = read_marker_candidates(primary)
    if marker_worktrees:
        return marker_worktrees

    worktrees = parse_worktree_list(require_git(primary, ["worktree", "list", "--porcelain"]))
    repo_name = primary.name
    parent = primary.parent
    prefix = str(parent / f"{repo_name}-")

    return [
        worktree
        for worktree in worktrees
        if worktree.path != primary and str(worktree.path).startswith(prefix)
    ]


def is_dirty(path: Path) -> bool:
    result = run_git(path, ["status", "--porcelain", "--untracked-files=all"])
    return bool(result.stdout.strip())


def collect_candidates(primary: Path, *, check_dirty: bool) -> list[Candidate]:
    candidates: list[Candidate] = []
    for worktree in candidate_worktrees(primary):
        if not check_dirty:
            candidates.append(Candidate(primary, worktree, dirty=None))
            continue

        if not worktree.path.exists():
            candidates.append(Candidate(primary, worktree, dirty=True))
        else:
            candidates.append(Candidate(primary, worktree, dirty=is_dirty(worktree.path)))
    return candidates


def display_path(path: Path, args: argparse.Namespace) -> str:
    display_base = getattr(args, "display_base", None)
    if display_base is None:
        return str(path)

    try:
        return str(path.relative_to(display_base))
    except ValueError:
        return str(path)


def print_candidate(candidate: Candidate, args: argparse.Namespace, *, action: str | None = None) -> None:
    if candidate.dirty is None:
        state = "candidate"
    else:
        state = "dirty" if candidate.dirty else "clean"

    if action == "skipped" and candidate.dirty:
        label = "skipped dirty"
    elif action is not None:
        label = action
    else:
        label = f"{state:<5}"
    print(f"  {label:<13} {display_path(candidate.worktree.path, args)}  [{candidate.worktree.branch}]")


def remove_candidate(candidate: Candidate, *, force: bool) -> None:
    args = ["worktree", "remove"]
    if force:
        args.append("--force")
    args.append(str(candidate.worktree.path))
    result = run_git(candidate.primary, args)
    if result.returncode != 0:
        message = result.stderr.strip() or f"failed to remove {candidate.worktree.path}"
        raise RuntimeError(message)


def cleanup_primaries(primaries: list[Path], args: argparse.Namespace) -> int:
    totals = Totals()
    repos_with_candidates = 0
    check_dirty = args.yes

    for primary in primaries:
        candidates = collect_candidates(primary, check_dirty=check_dirty)
        if not candidates:
            continue

        repos_with_candidates += 1
        print(f"\n{display_path(primary, args)} ({len(candidates)})")

        for candidate in candidates:
            if candidate.dirty is None:
                totals.clean += 1
            elif candidate.dirty:
                totals.dirty += 1
            else:
                totals.clean += 1

            if not args.yes:
                print_candidate(candidate, args)
                continue

            if candidate.dirty and not args.force:
                totals.skipped += 1
                print_candidate(candidate, args, action="skipped")
                continue

            remove_candidate(candidate, force=args.force)
            totals.removed += 1
            print_candidate(candidate, args, action="removed")

        if args.prune:
            require_git(primary, ["worktree", "prune"])
            print("  pruned   stale Git worktree metadata")

    if repos_with_candidates == 0:
        print("No launcher-style sibling worktrees found.")
        return 0

    print()
    if not args.yes:
        print(f"Summary: {totals.clean} candidates, 0 removed.")
        print("Dry run. Add --yes to check dirty state and remove clean worktrees.")
    else:
        print(
            f"Summary: {totals.clean} clean, {totals.dirty} dirty, "
            f"{totals.removed} removed, {totals.skipped} skipped."
        )

    return 0


def cleanup_candidates(candidates: list[Candidate], args: argparse.Namespace) -> int:
    if not candidates:
        print("No launcher-style sibling worktrees found.")
        return 0

    totals = Totals()
    by_primary: dict[Path, list[Candidate]] = {}
    for candidate in candidates:
        by_primary.setdefault(candidate.primary, []).append(candidate)

    for primary, primary_candidates in by_primary.items():
        print(f"\n{display_path(primary, args)} ({len(primary_candidates)})")
        for candidate in primary_candidates:
            candidate_to_print = candidate
            if args.yes:
                dirty = True if not candidate.worktree.path.exists() else is_dirty(candidate.worktree.path)
                candidate_to_print = Candidate(candidate.primary, candidate.worktree, dirty)

            if candidate_to_print.dirty is None:
                totals.clean += 1
            elif candidate_to_print.dirty:
                totals.dirty += 1
            else:
                totals.clean += 1

            if not args.yes:
                print_candidate(candidate_to_print, args)
                continue

            if candidate_to_print.dirty and not args.force:
                totals.skipped += 1
                print_candidate(candidate_to_print, args, action="skipped")
                continue

            remove_candidate(candidate_to_print, force=args.force)
            totals.removed += 1
            print_candidate(candidate_to_print, args, action="removed")

        if args.prune:
            require_git(primary, ["worktree", "prune"])
            print("  pruned       stale Git worktree metadata")

    print()
    if not args.yes:
        print(f"Summary: {totals.clean} candidates, 0 removed.")
        print("Dry run. Add --yes to check dirty state and remove clean worktrees.")
    else:
        print(
            f"Summary: {totals.clean} clean, {totals.dirty} dirty, "
            f"{totals.removed} removed, {totals.skipped} skipped."
        )

    return 0


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="codex cleanup",
        description="List and remove clean launcher-created sibling worktrees.",
    )
    parser.add_argument("-y", "--yes", action="store_true", help="remove clean candidates")
    parser.add_argument("--force", action="store_true", help="remove dirty candidates too; requires --yes")
    parser.add_argument("--prune", action="store_true", help="run git worktree prune after cleanup")
    parser.add_argument("--scan", action="append", default=[], metavar="DIR", help="scan for Git repos under DIR")
    parser.add_argument("--refresh", action="store_true", help="import existing worktrees into the local registry")
    parser.add_argument("--max-depth", type=int, default=4, metavar="N", help="limit --scan recursion depth")
    parser.add_argument("--unbounded", action="store_true", help="disable the scan depth limit")
    return parser.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)

    if args.force and not args.yes:
        print("codex cleanup: --force requires --yes", file=sys.stderr)
        return 2

    if args.max_depth < 0:
        print("codex cleanup: --max-depth must be non-negative", file=sys.stderr)
        return 2

    max_depth = None if args.unbounded else args.max_depth

    try:
        if args.scan:
            scan_roots = [canonical(scan_arg) for scan_arg in args.scan]
            args.display_base = Path(os.path.commonpath([str(root) for root in scan_roots]))

            for scan_root in scan_roots:
                if max_depth is None:
                    print(f"Scanning {scan_root} (unbounded)")
                else:
                    print(f"Scanning {scan_root} (max depth {max_depth})")

            if args.refresh:
                candidates = refresh_registry(scan_roots, max_depth)
            else:
                candidates = registry_candidates(scan_roots)

            if not candidates:
                for scan_root in scan_roots:
                    print(f"No Git repositories found under {scan_root}.")
                if not args.refresh:
                    print(f"Registry: {registry_path()}")
                    print("Run with --refresh to import existing worktrees.")
                return 0

            return cleanup_candidates(candidates, args)

        if not is_inside_git_repo():
            print("codex cleanup: run inside a Git repository, or use --scan DIR", file=sys.stderr)
            return 1

        primary = current_primary_worktree()
        args.display_base = primary.parent
        return cleanup_primaries([primary], args)
    except RuntimeError as error:
        print(f"codex cleanup: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
