#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: codex cleanup [OPTIONS]

List and remove clean launcher-created sibling worktrees.

Options:
  -y, --yes    Remove clean candidates. Without this, only list them.
      --force  Remove dirty candidates too. Requires --yes.
      --prune  Run git worktree prune after cleanup.
      --scan DIR
                Recursively find Git repos under DIR and clean each one.
  -h, --help   Show this help.
EOF
}

canonical_dir() {
  cd "$1"
  pwd -P
}

yes=false
force=false
prune=false
scan_roots=()

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    -y|--yes)
      yes=true
      ;;
    --force)
      force=true
      ;;
    --prune)
      prune=true
      ;;
    --scan)
      shift
      if [[ "${1:-}" == "" ]]; then
        printf 'codex cleanup: --scan requires a directory\n' >&2
        exit 2
      fi
      scan_roots+=("$(canonical_dir "$1")")
      ;;
    --scan=*)
      scan_roots+=("$(canonical_dir "${1#--scan=}")")
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'codex cleanup: unknown option: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

contains_path() {
  local needle="$1"
  shift
  local candidate

  for candidate in "$@"; do
    [[ "$candidate" == "$needle" ]] && return 0
  done

  return 1
}

primary_for_repo_path() {
  local repo_path="$1"
  local repo_root
  local primary_worktree

  repo_root="$(canonical_dir "$(git -C "$repo_path" rev-parse --show-toplevel)")"
  primary_worktree="$(git -C "$repo_root" worktree list --porcelain | awk 'NR == 1 && $1 == "worktree" { print substr($0, 10); exit }')"
  canonical_dir "$primary_worktree"
}

cleanup_primary_worktree() {
  local primary_worktree="$1"
  local repo_name
  local parent_dir
  local candidate_prefix
  local current_path=""
  local current_branch=""
  local paths=()
  local branches=()
  local removed=0
  local skipped=0
  local index
  local path
  local branch
  local status
  local state
  local remove_args

  repo_name="$(basename "$primary_worktree")"
  parent_dir="$(dirname "$primary_worktree")"
  candidate_prefix="$parent_dir/$repo_name-"

  flush_worktree() {
    if [[ -z "$current_path" ]]; then
      return
    fi

    if [[ "$current_path" != "$primary_worktree" && "$current_path" == "$candidate_prefix"* ]]; then
      paths+=("$current_path")
      branches+=("${current_branch:-detached}")
    fi

    current_path=""
    current_branch=""
  }

  while IFS= read -r line; do
    if [[ -z "$line" ]]; then
      flush_worktree
      continue
    fi

    case "$line" in
      worktree\ *)
        flush_worktree
        current_path="${line#worktree }"
        ;;
      branch\ refs/heads/*)
        current_branch="${line#branch refs/heads/}"
        ;;
      branch\ *)
        current_branch="${line#branch }"
        ;;
    esac
  done < <(git -C "$primary_worktree" worktree list --porcelain)

  flush_worktree

  printf 'Primary: %s\n' "$primary_worktree"

  if [[ "${#paths[@]}" -eq 0 ]]; then
    printf 'No launcher-style sibling worktrees found.\n'
    if [[ "$prune" == true ]]; then
      git -C "$primary_worktree" worktree prune
      printf 'Pruned stale Git worktree metadata.\n'
    fi
    return
  fi

  for index in "${!paths[@]}"; do
    path="${paths[$index]}"
    branch="${branches[$index]}"

    if [[ ! -d "$path" ]]; then
      printf 'missing %s [%s]\n' "$path" "$branch"
      skipped=$((skipped + 1))
      continue
    fi

    status="$(git -C "$path" status --porcelain --untracked-files=all)"
    if [[ -n "$status" ]]; then
      state="dirty"
    else
      state="clean"
    fi

    if [[ "$yes" != true ]]; then
      printf '%s %s [%s]\n' "$state" "$path" "$branch"
      continue
    fi

    if [[ "$state" == "dirty" && "$force" != true ]]; then
      printf 'skipped dirty %s [%s]\n' "$path" "$branch"
      skipped=$((skipped + 1))
      continue
    fi

    remove_args=(worktree remove)
    if [[ "$force" == true ]]; then
      remove_args+=(--force)
    fi
    remove_args+=("$path")

    git -C "$primary_worktree" "${remove_args[@]}"
    printf 'removed %s [%s]\n' "$path" "$branch"
    removed=$((removed + 1))
  done

  if [[ "$yes" != true ]]; then
    printf 'Dry run. Re-run with --yes to remove clean worktrees.\n'
  fi

  if [[ "$prune" == true ]]; then
    git -C "$primary_worktree" worktree prune
    printf 'Pruned stale Git worktree metadata.\n'
  fi

  printf 'Summary: %s removed, %s skipped.\n' "$removed" "$skipped"
}

scan_for_primary_worktrees() {
  local scan_root="$1"
  local git_marker
  local repo_dir
  local primary_worktree
  local primary_worktrees=()

  printf 'Scanning: %s\n' "$scan_root"

  while IFS= read -r git_marker; do
    repo_dir="$(dirname "$git_marker")"
    if ! primary_worktree="$(primary_for_repo_path "$repo_dir" 2>/dev/null)"; then
      continue
    fi

    if [[ "${#primary_worktrees[@]}" -eq 0 ]] || ! contains_path "$primary_worktree" "${primary_worktrees[@]}"; then
      primary_worktrees+=("$primary_worktree")
    fi
  done < <(
    find "$scan_root" \
      \( -type d \( -name node_modules -o -name .cache -o -name .next -o -name dist -o -name build \) -prune \) -o \
      \( -name .git \( -type d -o -type f \) -print \)
  )

  if [[ "${#primary_worktrees[@]}" -eq 0 ]]; then
    printf 'No Git repositories found under %s.\n' "$scan_root"
    return
  fi

  for primary_worktree in "${primary_worktrees[@]}"; do
    cleanup_primary_worktree "$primary_worktree"
  done
}

if [[ "$force" == true && "$yes" != true ]]; then
  printf 'codex cleanup: --force requires --yes\n' >&2
  exit 2
fi

if [[ "${#scan_roots[@]}" -gt 0 ]]; then
  for scan_root in "${scan_roots[@]}"; do
    scan_for_primary_worktrees "$scan_root"
  done
  exit 0
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  printf 'codex cleanup: run inside a Git repository\n' >&2
  exit 1
fi

cleanup_primary_worktree "$(primary_for_repo_path "$(pwd -P)")"
