#!/usr/bin/env bash
set -euo pipefail

CODEX_BIN="${CODEX_BIN:-/opt/homebrew/bin/codex}"

value_options=(
  -a --ask-for-approval
  -c --config
  -i --image
  -m --model
  -o --output-last-message
  -p --profile
  -s --sandbox
  --add-dir
  --base
  --color
  --commit
  --disable
  --enable
  --local-provider
  --output-schema
  --remote
  --remote-auth-token-env
  --title
)

option_takes_value() {
  local option="$1"
  local value_option

  for value_option in "${value_options[@]}"; do
    [[ "$option" == "$value_option" ]] && return 0
  done

  return 1
}

prompt_from_args() {
  local skip_next=false
  local after_dashdash=false
  local arg
  local prompt_parts=()

  for arg in "$@"; do
    if [[ "$skip_next" == true ]]; then
      skip_next=false
      continue
    fi

    if [[ "$after_dashdash" == false ]]; then
      case "$arg" in
        exec|review)
          continue
          ;;
        --)
          after_dashdash=true
          continue
          ;;
        --*=*)
          continue
          ;;
        -*)
          if option_takes_value "$arg"; then
            skip_next=true
          fi
          continue
          ;;
      esac
    fi

    prompt_parts+=("$arg")
  done

  if [[ "${#prompt_parts[@]}" -gt 0 ]]; then
    printf '%s\n' "${prompt_parts[*]}"
  fi
}

slugify() {
  local value="$1"

  printf '%s' "$value" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g' \
    | cut -c 1-64 \
    | sed -E 's/[._-]+$//'
}

is_slug_filler_word() {
  case "$1" in
    a|an|and|are|as|at|be|can|could|do|does|doing|for|from|have|how|i|id|if|in|into|is|it|just|like|me|mind|my|of|ok|okay|on|only|or|please|pls|should|that|the|this|to|we|what|when|why|with|would|you|your)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

slug_from_prompt() {
  local value="$1"
  local word
  local slug=""
  local candidate
  local kept=0

  while IFS= read -r word; do
    [[ -z "$word" ]] && continue
    is_slug_filler_word "$word" && continue

    candidate="${slug:+$slug-}$word"
    if [[ "$kept" -gt 0 && "${#candidate}" -gt 40 ]]; then
      break
    fi

    slug="$candidate"
    kept=$((kept + 1))

    if [[ "$kept" -ge 4 ]]; then
      break
    fi
  done < <(
    printf '%s\n' "$value" \
      | tr '[:upper:]' '[:lower:]' \
      | sed -E 's/[^a-z0-9]+/\n/g'
  )

  if [[ -z "$slug" ]]; then
    slug="$(slugify "$value")"
  fi

  printf '%s' "$slug" | cut -c 1-48 | sed -E 's/[._-]+$//'
}

slug_from_codex() {
  local value="$1"
  local model="${CODEX_WORKTREE_NAMER_MODEL:-gpt-5.1-codex}"
  local timeout_seconds="${CODEX_WORKTREE_NAMER_TIMEOUT:-8}"

  command -v python3 >/dev/null 2>&1 || return 1
  [[ -x "$CODEX_BIN" ]] || command -v "$CODEX_BIN" >/dev/null 2>&1 || return 1

  CODEX_NAMER_PROMPT="$value" python3 - "$CODEX_BIN" "$model" "$timeout_seconds" <<'PY'
from __future__ import annotations

import os
import re
import subprocess
import sys
import tempfile
from pathlib import Path

codex_bin = sys.argv[1]
model = sys.argv[2]

try:
    timeout_seconds = max(1, int(sys.argv[3]))
except ValueError:
    timeout_seconds = 8

task = os.environ.get("CODEX_NAMER_PROMPT", "")
if not task.strip():
    raise SystemExit(1)

prompt = f"""Create a git branch/worktree slug for this task.

Rules:
- Return only the slug.
- Use lowercase kebab-case.
- Use 2 to 5 meaningful words.
- Max 48 characters.
- No username, repo name, ticket prefix, quotes, or explanation.

Task:
{task}
"""

with tempfile.TemporaryDirectory() as tmpdir:
    output_path = Path(tmpdir) / "slug.txt"
    command = [
        codex_bin,
        "exec",
        "--ephemeral",
        "--skip-git-repo-check",
        "--ignore-rules",
        "--disable",
        "hooks",
        "--color",
        "never",
        "-c",
        'model_reasoning_effort="none"',
        "-s",
        "read-only",
        "-C",
        tmpdir,
        "-m",
        model,
        "-o",
        str(output_path),
        prompt,
    ]

    try:
        subprocess.run(
            command,
            check=True,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=timeout_seconds,
        )
    except (OSError, subprocess.CalledProcessError, subprocess.TimeoutExpired):
        raise SystemExit(1)

    try:
        raw_slug = output_path.read_text(encoding="utf-8").strip().splitlines()[0]
    except (OSError, IndexError):
        raise SystemExit(1)

slug = re.sub(r"[^a-z0-9]+", "-", raw_slug.lower()).strip("-")[:48].strip("-")
if not re.fullmatch(r"[a-z0-9][a-z0-9-]{1,47}", slug):
    raise SystemExit(1)

print(slug)
PY
}

name_slug() {
  local value="$1"
  local namer="${CODEX_WORKTREE_NAMER:-local}"
  local slug=""

  case "$namer" in
    codex)
      slug="$(slug_from_codex "$value" 2>/dev/null || true)"
      ;;
    local)
      ;;
    *)
      printf 'codex-worktree: unknown CODEX_WORKTREE_NAMER=%s\n' "$namer" >&2
      return 1
      ;;
  esac

  if [[ -z "$slug" ]]; then
    slug="$(slug_from_prompt "$value")"
  fi

  printf '%s\n' "$slug"
}

default_base_branch() {
  local origin_head
  local current_branch

  origin_head="$(git -C "$repo_root" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"
  if [[ -n "$origin_head" ]]; then
    printf '%s\n' "${origin_head#origin/}"
    return
  fi

  if git -C "$repo_root" show-ref --verify --quiet refs/remotes/origin/main ||
    git -C "$repo_root" show-ref --verify --quiet refs/heads/main; then
    printf 'main\n'
    return
  fi

  if git -C "$repo_root" show-ref --verify --quiet refs/remotes/origin/master ||
    git -C "$repo_root" show-ref --verify --quiet refs/heads/master; then
    printf 'master\n'
    return
  fi

  current_branch="$(git -C "$repo_root" branch --show-current 2>/dev/null || true)"
  printf '%s\n' "${current_branch:-main}"
}

first_arg="${1:-}"

for arg in "$@"; do
  case "$arg" in
    -C|--cd|--help|-h|--version|-V)
      exec "$CODEX_BIN" "$@"
      ;;
  esac
done

case "$first_arg" in
  help|login|logout|mcp|plugin|mcp-server|app|app-server|exec-server|remote-control|completion|update|doctor|features|archive|unarchive|fork|resume|cloud|sandbox|debug|apply|cleanup|worktrees)
    exec "$CODEX_BIN" "$@"
    ;;
esac

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  exec "$CODEX_BIN" "$@"
fi

canonical_dir() {
  cd "$1"
  pwd -P
}

repo_root="$(canonical_dir "$(git rev-parse --show-toplevel)")"
primary_worktree="$(git -C "$repo_root" worktree list --porcelain | awk 'NR == 1 && $1 == "worktree" { print substr($0, 10); exit }')"
primary_worktree="$(canonical_dir "$primary_worktree")"

if [[ "$repo_root" != "$primary_worktree" ]]; then
  exec "$CODEX_BIN" -C "$repo_root" "$@"
fi

repo_name="$(basename "$repo_root")"
parent_dir="$(dirname "$repo_root")"

prompt_text="$(prompt_from_args "$@")"
if [[ -z "$prompt_text" && -t 0 && -t 1 ]]; then
  printf 'What are we working on? (Enter = use this checkout): ' >&2
  IFS= read -r prompt_text

  if [[ -n "$prompt_text" ]]; then
    set -- "$@" "$prompt_text"
  fi
fi

if [[ -z "$prompt_text" ]]; then
  exec "$CODEX_BIN" "$@"
fi

slug="${CODEX_WORKTREE_SLUG:-}"
if [[ -z "$slug" ]]; then
  slug="$(name_slug "$prompt_text")"
else
  slug="$(slugify "$slug")"
fi

if [[ -z "$slug" ]]; then
  exec "$CODEX_BIN" "$@"
fi

base_branch="${CODEX_WORKTREE_BASE:-}"
if [[ -z "$base_branch" ]]; then
  base_branch="$(default_base_branch)"
fi
base_branch="${base_branch:-main}"

worktree_dir="${CODEX_WORKTREE_DIR:-$parent_dir/$repo_name-$slug}"
branch_name="${CODEX_WORKTREE_BRANCH:-jesse/$slug}"

if [[ ! -e "$worktree_dir/.git" ]]; then
  if [[ -e "$worktree_dir" ]]; then
    printf 'codex-worktree: %s exists but is not a git worktree\n' "$worktree_dir" >&2
    exit 1
  fi

  if [[ "${CODEX_WORKTREE_FETCH:-0}" == "1" ]] &&
    git -C "$repo_root" remote get-url origin >/dev/null 2>&1; then
    git -C "$repo_root" fetch origin "$base_branch" --quiet || true
  fi

  if git -C "$repo_root" rev-parse --verify --quiet "$branch_name" >/dev/null; then
    git -C "$repo_root" worktree add "$worktree_dir" "$branch_name"
  elif git -C "$repo_root" rev-parse --verify --quiet "origin/$branch_name" >/dev/null; then
    git -C "$repo_root" worktree add -b "$branch_name" "$worktree_dir" "origin/$branch_name"
  elif git -C "$repo_root" rev-parse --verify --quiet "origin/$base_branch" >/dev/null; then
    git -C "$repo_root" worktree add -b "$branch_name" "$worktree_dir" "origin/$base_branch"
  else
    git -C "$repo_root" worktree add -b "$branch_name" "$worktree_dir" "$base_branch"
  fi
fi

printf 'codex-worktree: %s\n' "$worktree_dir" >&2
printf 'codex-worktree: %s\n' "$branch_name" >&2

exec "$CODEX_BIN" -C "$worktree_dir" "$@"
