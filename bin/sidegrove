#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: sidegrove <cli> [args...]

Runs an agent CLI in a task-specific Git worktree. Known CLIs get
tailored argument handling: codex, claude. Any other CLI gets safe
generic handling.

Normally invoked through the shell aliases added by scripts/install.sh:

  alias codex='sidegrove codex'
  alias claude='sidegrove claude'
EOF
}

cli="${1:-}"

case "$cli" in
  -h|--help)
    usage
    exit 0
    ;;
  '')
    usage
    exit 2
    ;;
esac

shift

resolve_cli_bin() {
  local candidate

  while IFS= read -r candidate; do
    if [[ ! "$candidate" -ef "${BASH_SOURCE[0]}" ]]; then
      printf '%s\n' "$candidate"
      return
    fi
  done < <(type -ap "$cli")
}

cli_bin="${SIDEGROVE_BIN:-$(resolve_cli_bin)}"

if [[ -z "$cli_bin" ]]; then
  printf 'sidegrove: %s not found in PATH; set SIDEGROVE_BIN\n' "$cli" >&2
  exit 1
fi

# Options that consume the next argument, so prompt extraction skips it.
cli_value_options() {
  case "$cli" in
    codex)
      printf '%s' '-a --ask-for-approval -c --config -i --image -m --model
        -o --output-last-message -p --profile -s --sandbox --add-dir --base
        --color --commit --disable --enable --local-provider --output-schema
        --remote --remote-auth-token-env --title'
      ;;
    claude)
      printf '%s' '--add-dir --agent --agents --allowedTools --allowed-tools
        --append-system-prompt --betas -d --debug --debug-file
        --disallowedTools --disallowed-tools --effort --fallback-model --file
        --input-format --json-schema --max-budget-usd --mcp-config --model
        -n --name --output-format --permission-mode --plugin-dir --plugin-url
        --remote-control-session-name-prefix --session-id --setting-sources
        --settings --system-prompt --tools'
      ;;
    *)
      printf '%s' '-m --model'
      ;;
  esac
}

# Subcommands that manage the CLI itself; never start a worktree session.
cli_passthrough_subcommands() {
  case "$cli" in
    codex)
      printf '%s' 'help login logout mcp plugin mcp-server app app-server
        exec-server remote-control completion update doctor features archive
        unarchive fork resume cloud sandbox debug apply cleanup worktrees'
      ;;
    claude)
      printf '%s' 'agents auth auto-mode doctor install mcp plugin plugins
        project setup-token ultrareview update upgrade'
      ;;
    *)
      printf '%s' 'help login logout config doctor update completion version'
      ;;
  esac
}

# Flags anywhere in the arguments that mean "not a fresh task session":
# resume flows, print mode, and the CLI's own worktree handling.
cli_passthrough_flags() {
  case "$cli" in
    codex)
      printf '%s' '-C --cd'
      ;;
    claude)
      printf '%s' '-c --continue -r --resume --from-pr -w --worktree -p --print'
      ;;
    *)
      printf '%s' ''
      ;;
  esac
}

# Subcommands that still carry a task prompt worth a worktree.
cli_prompt_subcommands() {
  case "$cli" in
    codex)
      printf '%s' 'exec review'
      ;;
    *)
      printf '%s' ''
      ;;
  esac
}

default_namer_model() {
  case "$cli" in
    codex)
      printf 'gpt-5.1-codex'
      ;;
    claude)
      printf 'haiku'
      ;;
    *)
      printf ''
      ;;
  esac
}

value_options="$(cli_value_options)"
passthrough_subcommands="$(cli_passthrough_subcommands)"
passthrough_flags="$(cli_passthrough_flags)"
prompt_subcommands="$(cli_prompt_subcommands)"

list_contains() {
  local needle="$1"
  local item

  # $2 is a whitespace-separated list; word splitting is intentional.
  for item in $2; do
    [[ "$item" == "$needle" ]] && return 0
  done

  return 1
}

prompt_from_args() {
  local skip_next=false
  local after_dashdash=false
  local arg
  local prompt_parts=()

  for arg in "$@"; do
    if [[ "$skip_next" == true ]]; then
      skip_next=false
      continue
    fi

    if [[ "$after_dashdash" == false ]]; then
      if [[ "$arg" == "--" ]]; then
        after_dashdash=true
        continue
      fi

      if list_contains "$arg" "$prompt_subcommands"; then
        continue
      fi

      case "$arg" in
        --*=*)
          continue
          ;;
        -*)
          if list_contains "$arg" "$value_options"; then
            skip_next=true
          fi
          continue
          ;;
      esac
    fi

    prompt_parts+=("$arg")
  done

  if [[ "${#prompt_parts[@]}" -gt 0 ]]; then
    printf '%s\n' "${prompt_parts[*]}"
  fi
}

slugify() {
  local value="$1"

  printf '%s' "$value" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g' \
    | cut -c 1-64 \
    | sed -E 's/[._-]+$//'
}

is_slug_filler_word() {
  case "$1" in
    a|an|and|are|as|at|be|can|could|do|does|doing|for|from|have|how|i|id|if|in|into|is|it|just|like|me|mind|my|of|ok|okay|on|only|or|please|pls|should|that|the|this|to|we|what|when|why|with|would|you|your)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

slug_from_prompt() {
  local value="$1"
  local word
  local slug=""
  local candidate
  local kept=0

  while IFS= read -r word; do
    [[ -z "$word" ]] && continue
    is_slug_filler_word "$word" && continue

    candidate="${slug:+$slug-}$word"
    if [[ "$kept" -gt 0 && "${#candidate}" -gt 40 ]]; then
      break
    fi

    slug="$candidate"
    kept=$((kept + 1))

    if [[ "$kept" -ge 4 ]]; then
      break
    fi
  done < <(
    printf '%s\n' "$value" \
      | tr '[:upper:]' '[:lower:]' \
      | sed -E 's/[^a-z0-9]+/\n/g'
  )

  if [[ -z "$slug" ]]; then
    slug="$(slugify "$value")"
  fi

  printf '%s' "$slug" | cut -c 1-48 | sed -E 's/[._-]+$//'
}

slug_from_agent() {
  local value="$1"
  local model="${SIDEGROVE_NAMER_MODEL:-$(default_namer_model)}"
  local timeout_seconds="${SIDEGROVE_NAMER_TIMEOUT:-8}"

  command -v python3 >/dev/null 2>&1 || return 1
  [[ -x "$cli_bin" ]] || command -v "$cli_bin" >/dev/null 2>&1 || return 1

  SIDEGROVE_NAMER_PROMPT="$value" python3 - "$cli" "$cli_bin" "$model" "$timeout_seconds" <<'PY'
from __future__ import annotations

import os
import re
import subprocess
import sys
import tempfile
from pathlib import Path

cli = sys.argv[1]
cli_bin = sys.argv[2]
model = sys.argv[3]

try:
    timeout_seconds = max(1, int(sys.argv[4]))
except ValueError:
    timeout_seconds = 8

task = os.environ.get("SIDEGROVE_NAMER_PROMPT", "")
if not task.strip():
    raise SystemExit(1)

prompt = f"""Create a git branch/worktree slug for this task.

Rules:
- Return only the slug.
- Use lowercase kebab-case.
- Use 2 to 5 meaningful words.
- Max 48 characters.
- No username, repo name, ticket prefix, quotes, or explanation.

Task:
{task}
"""

with tempfile.TemporaryDirectory() as tmpdir:
    output_path = Path(tmpdir) / "slug.txt"

    if cli == "codex":
        command = [
            cli_bin,
            "exec",
            "--ephemeral",
            "--skip-git-repo-check",
            "--ignore-rules",
            "--disable",
            "hooks",
            "--color",
            "never",
            "-c",
            'model_reasoning_effort="none"',
            "-s",
            "read-only",
            "-C",
            tmpdir,
            "-m",
            model,
            "-o",
            str(output_path),
            prompt,
        ]
    elif cli == "claude":
        command = [
            cli_bin,
            "-p",
            prompt,
            "--tools",
            "",
            "--no-session-persistence",
        ]
        if model:
            command += ["--model", model]
    else:
        raise SystemExit(1)

    try:
        result = subprocess.run(
            command,
            check=True,
            cwd=tmpdir,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            timeout=timeout_seconds,
        )
    except (OSError, subprocess.CalledProcessError, subprocess.TimeoutExpired):
        raise SystemExit(1)

    if cli == "codex":
        try:
            raw_slug = output_path.read_text(encoding="utf-8").strip().splitlines()[0]
        except (OSError, IndexError):
            raise SystemExit(1)
    else:
        lines = [line for line in result.stdout.decode("utf-8").splitlines() if line.strip()]
        if not lines:
            raise SystemExit(1)
        raw_slug = lines[-1].strip()

slug = re.sub(r"[^a-z0-9]+", "-", raw_slug.lower()).strip("-")[:48].strip("-")
if not re.fullmatch(r"[a-z0-9][a-z0-9-]{1,47}", slug):
    raise SystemExit(1)

print(slug)
PY
}

name_slug() {
  local value="$1"
  local namer="${SIDEGROVE_NAMER:-local}"
  local slug=""

  case "$namer" in
    agent)
      slug="$(slug_from_agent "$value" 2>/dev/null || true)"
      ;;
    local)
      ;;
    *)
      printf 'sidegrove: unknown SIDEGROVE_NAMER=%s\n' "$namer" >&2
      return 1
      ;;
  esac

  if [[ -z "$slug" ]]; then
    slug="$(slug_from_prompt "$value")"
  fi

  printf '%s\n' "$slug"
}

supports_styled_prompt() {
  [[ -t 2 ]] || return 1
  [[ -z "${NO_COLOR:-}" ]] || return 1
  [[ "${TERM:-}" != "dumb" ]] || return 1
}

terminal_columns() {
  local columns="${COLUMNS:-}"

  if [[ ! "$columns" =~ ^[0-9]+$ ]] || [[ "$columns" -lt 40 ]]; then
    columns="$(tput cols 2>/dev/null || printf '80')"
  fi

  if [[ ! "$columns" =~ ^[0-9]+$ ]] || [[ "$columns" -lt 40 ]]; then
    columns=80
  fi

  printf '%s\n' "$columns"
}

# Reads a line of input on a Codex-style grey band into band_reply.
# An optional dim header row sits above the "› " input row.
read_band_reply() {
  local header="$1"
  local label="$2"
  local columns

  columns="$(terminal_columns)"
  band_reply=""

  printf '\033[48;5;236m%*s\n' "$columns" '' >&2
  if [[ -n "$header" ]]; then
    printf '\033[48;5;236m%*s\r' "$columns" '' >&2
    printf '  \033[2m%s\033[22m\n' "$header" >&2
  fi
  printf '\033[48;5;236m%*s\n' "$columns" '' >&2
  printf '\033[48;5;236m%*s\033[0m\r' "$columns" '' >&2
  printf '\033[1A\033[48;5;236m\033[2m›\033[22m %s' "$label" >&2
  IFS= read -r band_reply || band_reply=""
  # After Enter the cursor sits on the bottom padding row. Cursor-down
  # cannot move past the last screen row, so use a real newline, which
  # scrolls when the band is at the bottom of the screen.
  printf '\033[0m\n' >&2
}

read_worktree_prompt() {
  if supports_styled_prompt; then
    read_band_reply 'Describe the task' ''
    prompt_text="$band_reply"
  else
    printf '\nDescribe the task\n> ' >&2
    IFS= read -r prompt_text || prompt_text=""
  fi
}

display_path() {
  local path="$1"

  case "$path" in
    "$HOME"/*)
      printf '~%s\n' "${path#"$HOME"}"
      ;;
    *)
      printf '%s\n' "$path"
      ;;
  esac
}

cleanup_command() {
  printf 'git -C %q worktree remove %q' "$repo_root" "$worktree_dir"
}

branch_is_merged_into_base() {
  local base_ref

  for base_ref in "origin/$base_branch" "$base_branch"; do
    if git -C "$repo_root" rev-parse --verify --quiet "$base_ref" >/dev/null &&
      git -C "$repo_root" merge-base --is-ancestor "$branch_name" "$base_ref" 2>/dev/null; then
      return 0
    fi
  done

  return 1
}

offer_worktree_cleanup() {
  local answer

  [[ -e "$worktree_dir/.git" ]] || return 0

  if supports_styled_prompt; then
    printf '\n' >&2
    read_band_reply '' "Clean up worktree $(display_path "$worktree_dir")? [y/N] "
    answer="$band_reply"
  else
    printf '\n> Clean up worktree %s? [y/N] ' "$(display_path "$worktree_dir")" >&2
    IFS= read -r answer || answer=""
  fi

  case "$answer" in
    y|Y|yes|Yes|YES)
      printf 'sidegrove: removing %s ...\n' "$(display_path "$worktree_dir")" >&2
      if git -C "$repo_root" worktree remove "$worktree_dir"; then
        printf 'sidegrove: removed %s\n' "$(display_path "$worktree_dir")" >&2
        if branch_is_merged_into_base &&
          git -C "$repo_root" branch -D "$branch_name" >/dev/null 2>&1; then
          printf 'sidegrove: deleted branch %s\n' "$branch_name" >&2
        else
          printf 'sidegrove: kept branch %s (has commits not on %s); delete with:\n\n  git -C %q branch -D %q\n' \
            "$branch_name" "$base_branch" "$repo_root" "$branch_name" >&2
        fi
      else
        printf 'sidegrove: not removed; clean up later with:\n\n  %s\n' "$(cleanup_command)" >&2
      fi
      ;;
    *)
      printf 'sidegrove: keeping worktree; clean up later with:\n\n  %s\n' "$(cleanup_command)" >&2
      ;;
  esac
}

default_base_branch() {
  local origin_head
  local current_branch

  origin_head="$(git -C "$repo_root" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"
  if [[ -n "$origin_head" ]]; then
    printf '%s\n' "${origin_head#origin/}"
    return
  fi

  if git -C "$repo_root" show-ref --verify --quiet refs/remotes/origin/main ||
    git -C "$repo_root" show-ref --verify --quiet refs/heads/main; then
    printf 'main\n'
    return
  fi

  if git -C "$repo_root" show-ref --verify --quiet refs/remotes/origin/master ||
    git -C "$repo_root" show-ref --verify --quiet refs/heads/master; then
    printf 'master\n'
    return
  fi

  current_branch="$(git -C "$repo_root" branch --show-current 2>/dev/null || true)"
  printf '%s\n' "${current_branch:-main}"
}

default_branch_prefix() {
  local git_user_name
  local prefix=""

  git_user_name="$(git -C "$repo_root" config user.name 2>/dev/null || true)"
  if [[ -n "$git_user_name" ]]; then
    prefix="$(slugify "${git_user_name%% *}")"
  fi

  if [[ -z "$prefix" && -n "${USER:-}" ]]; then
    prefix="$(slugify "$USER")"
  fi

  printf '%s\n' "${prefix:-agent}"
}

first_arg="${1:-}"

for arg in "$@"; do
  case "$arg" in
    -h|--help|-V|-v|--version)
      exec "$cli_bin" "$@"
      ;;
  esac

  if list_contains "$arg" "$passthrough_flags"; then
    exec "$cli_bin" "$@"
  fi
done

if [[ -n "$first_arg" ]] && list_contains "$first_arg" "$passthrough_subcommands"; then
  exec "$cli_bin" "$@"
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  exec "$cli_bin" "$@"
fi

canonical_dir() {
  cd "$1"
  pwd -P
}

repo_root="$(canonical_dir "$(git rev-parse --show-toplevel)")"
primary_worktree="$(git -C "$repo_root" worktree list --porcelain | awk 'NR == 1 && $1 == "worktree" { print substr($0, 10); exit }')"
primary_worktree="$(canonical_dir "$primary_worktree")"

if [[ "$repo_root" != "$primary_worktree" ]]; then
  cd "$repo_root"
  exec "$cli_bin" "$@"
fi

repo_name="$(basename "$repo_root")"
parent_dir="$(dirname "$repo_root")"

prompt_text="$(prompt_from_args "$@")"
if [[ -z "$prompt_text" && -t 0 && -t 1 ]]; then
  read_worktree_prompt

  if [[ -n "$prompt_text" ]]; then
    set -- "$@" "$prompt_text"
  fi
fi

if [[ -z "$prompt_text" ]]; then
  exec "$cli_bin" "$@"
fi

slug="${SIDEGROVE_SLUG:-}"
if [[ -z "$slug" ]]; then
  slug="$(name_slug "$prompt_text")"
else
  slug="$(slugify "$slug")"
fi

if [[ -z "$slug" ]]; then
  exec "$cli_bin" "$@"
fi

base_branch="${SIDEGROVE_BASE:-}"
if [[ -z "$base_branch" ]]; then
  base_branch="$(default_base_branch)"
fi
base_branch="${base_branch:-main}"

branch_prefix="${SIDEGROVE_BRANCH_PREFIX:-}"
if [[ -z "$branch_prefix" ]]; then
  branch_prefix="$(default_branch_prefix)"
fi

worktree_dir="${SIDEGROVE_DIR:-$parent_dir/$repo_name-$slug}"
branch_name="${SIDEGROVE_BRANCH:-$branch_prefix/$slug}"

if [[ ! -e "$worktree_dir/.git" ]]; then
  if [[ -e "$worktree_dir" ]]; then
    printf 'sidegrove: %s exists but is not a git worktree\n' "$worktree_dir" >&2
    exit 1
  fi

  if [[ "${SIDEGROVE_FETCH:-0}" == "1" ]] &&
    git -C "$repo_root" remote get-url origin >/dev/null 2>&1; then
    git -C "$repo_root" fetch origin "$base_branch" --quiet || true
  fi

  if git -C "$repo_root" rev-parse --verify --quiet "$branch_name" >/dev/null; then
    git -C "$repo_root" worktree add "$worktree_dir" "$branch_name"
  elif git -C "$repo_root" rev-parse --verify --quiet "origin/$branch_name" >/dev/null; then
    git -C "$repo_root" worktree add -b "$branch_name" "$worktree_dir" "origin/$branch_name"
  elif git -C "$repo_root" rev-parse --verify --quiet "origin/$base_branch" >/dev/null; then
    git -C "$repo_root" worktree add -b "$branch_name" "$worktree_dir" "origin/$base_branch"
  else
    git -C "$repo_root" worktree add -b "$branch_name" "$worktree_dir" "$base_branch"
  fi
fi

printf 'sidegrove: %s on %s\n' "$(display_path "$worktree_dir")" "$branch_name" >&2

if [[ "${SIDEGROVE_CLEANUP_PROMPT:-1}" != "1" || ! -t 0 || ! -t 1 ]]; then
  cd "$worktree_dir"
  exec "$cli_bin" "$@"
fi

cli_status=0
(cd "$worktree_dir" && "$cli_bin" "$@") || cli_status=$?

offer_worktree_cleanup

exit "$cli_status"
